{
  "name": "clickup-acme-governance",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node server.mjs",
    "worker": "node scripts/sync-all-daemon.mjs",
    "bootstrap:dry": "node scripts/bootstrap-clickup.mjs --dry-run",
    "bootstrap": "node scripts/bootstrap-clickup.mjs --live",
    "templates:dry": "node scripts/seed-clickup-templates.mjs --dry-run",
    "templates:seed": "node scripts/seed-clickup-templates.mjs --live",
    "fields:dry": "node scripts/seed-clickup-custom-fields.mjs --dry-run",
    "fields:seed": "node scripts/seed-clickup-custom-fields.mjs --live",
    "webhook:register": "node scripts/register-clickup-webhook.mjs",
    "contracts:generate": "node scripts/generate-event-contracts.mjs",
    "validate": "node scripts/validate.mjs",
    "test": "node tests/tech-tasks.test.mjs && node tests/aios-modules.test.mjs && node tests/validate.test.mjs",
    "model:generate": "node scripts/generate-operating-model-docs.mjs",
    "activities:dry": "node scripts/seed-activities.mjs --dry-run",
    "activities:seed": "node scripts/seed-activities.mjs --live",
    "activities:agentic:dry": "node scripts/seed-activities.mjs --dry-run --delivery-type=agentic_saas",
    "activities:platform:dry": "node scripts/seed-activities.mjs --dry-run --delivery-type=platform",
    "tech:dry": "node scripts/generate-tech-tasks.mjs --dry-run",
    "tech:generate": "node scripts/generate-tech-tasks.mjs --live",
    "tech:progress": "node scripts/read-tech-progress.mjs",
    "tech:sync": "node scripts/sync-tech-status.mjs",
    "tech:model": "node scripts/generate-tech-operating-doc.mjs",
    "platform:dry": "node scripts/generate-aios-modules.mjs --dry-run",
    "platform:generate": "node scripts/generate-aios-modules.mjs --live",
    "platform:sync": "node scripts/sync-aios-status.mjs --dry-run",
    "platform:sync:live": "node scripts/sync-aios-status.mjs --live",
    "aios:dry": "node scripts/generate-aios-modules.mjs --dry-run",
    "aios:generate": "node scripts/generate-aios-modules.mjs --live",
    "aios:sync": "node scripts/sync-aios-status.mjs --dry-run --platform=\"Plataforma SchoolPlatform\"",
    "aios:sync:live": "node scripts/sync-aios-status.mjs --live --platform=\"Plataforma SchoolPlatform\"",
    "aios:daemon": "node scripts/aios-sync-daemon.mjs --live --platform=\"Plataforma SchoolPlatform\"",
    "aicfo:dry": "node scripts/generate-aios-modules.mjs --dry-run --payload-file=examples/aicfo-modules.payload.json",
    "aicfo:generate": "node scripts/generate-aios-modules.mjs --live --payload-file=examples/aicfo-modules.payload.json",
    "aicfo:sync": "node scripts/sync-aios-status.mjs --dry-run --platform=\"Plataforma Aicfo\"",
    "aicfo:sync:live": "node scripts/sync-aios-status.mjs --live --platform=\"Plataforma Aicfo\"",
    "aicfo:daemon": "node scripts/aios-sync-daemon.mjs --live --platform=\"Plataforma Aicfo\"",
    "aicfo:frontend:dry": "node scripts/generate-aicfo-frontend-list.mjs",
    "aicfo:frontend:generate": "node scripts/generate-aicfo-frontend-list.mjs --live",
    "aicfo:update-descriptions:dry": "node scripts/update-aicfo-descriptions.mjs --dry-run",
    "aicfo:update-descriptions": "node scripts/update-aicfo-descriptions.mjs --live",
    "marketing-ai-agents:bootstrap": "node scripts/bootstrap-marketing-ai-agents-repo.mjs",
    "marketing-ai-agents:sync:dry": "node scripts/sync-marketing-ai-agents-from-forge.mjs --dry-run",
    "marketing-ai-agents:sync": "node scripts/sync-marketing-ai-agents-from-forge.mjs --live"
  },
  "engines": {
    "node": ">=18"
  }
}
