{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(node scripts/validate.mjs)",
      "Bash(node scripts/seed-clickup-templates.mjs --dry-run)",
      "Bash(node scripts/bootstrap-clickup.mjs --dry-run)",
      "Bash(node -e ' *)",
      "Bash(git commit -m ' *)",
      "Bash(git commit *)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add*)",
      "Bash(git fetch *)",
      "WebSearch",
      "WebFetch"
    ],
    "deny": [
      "Bash(rm -rf*)",
      "Bash(rm -fr*)",
      "Bash(npm publish*)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash hooks/session-start/foundry-context.sh",
            "timeout": 5000
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash hooks/stop/5-gates-summary.sh",
            "timeout": 30000
          },
          {
            "type": "command",
            "command": "bash hooks/stop/eval-suite-fresh.sh",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "bash hooks/stop/learning-snapshot.sh",
            "timeout": 10000
          }
        ]
      }
    ]
  },
  "_comment": "Novais Digital Foundry layer (versioned). Per-developer overrides go in settings.local.json (gitignored).",
  "_foundry_version": "0.21.0",
  "_constitution_version": "0.3.0",
  "_foundry_features": {
    "skills_path": ".claude/skills/{L0,L1,L2}/",
    "agents_path": ".claude/agents/",
    "hooks_path": "hooks/",
    "bypass_env_var": "NOVAIS_FOUNDRY_BYPASS",
    "bypass_log_path": "docs/foundry/bypass-log/",
    "bypass_note": "Set NOVAIS_FOUNDRY_BYPASS=<reason> in settings.local.json or env. All bypasses are logged."
  }
}
