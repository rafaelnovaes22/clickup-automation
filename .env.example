# ClickUp credenciais (obrigatorias)
CLICKUP_TOKEN=pk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLICKUP_TEAM_ID=123456789

# Aliases suportados pelo backend Acme (alternativos as variaveis acima):
ACME_INTERNAL_CLICKUP_TOKEN=pk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ACME_INTERNAL_WORKSPACE_ID=123456789

# Webhook ClickUp -> backend
# OBRIGATORIO em producao (NODE_ENV=production). O server recusa subir sem este valor.
# Em dev, pode ficar vazio: nesse caso, validacao de assinatura e DESLIGADA com aviso explicito no log.
CLICKUP_WEBHOOK_SECRET=

# Ambiente runtime
NODE_ENV=development
PORT=3000

# GitHub (opcional, usado pelos sync de evidencia tech/AIOS)
# Necessario para que o sync consulte PRs/branches/CI ao decidir status. Sem ele, o sync roda em modo offline/dry-run.
GITHUB_TOKEN=
# Alias suportado:
GH_TOKEN=
