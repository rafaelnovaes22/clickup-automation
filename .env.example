# ClickUp credenciais (obrigatorias)
CLICKUP_TOKEN=pk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLICKUP_TEAM_ID=123456789

# Aliases suportados pelo backend Novais Digital (alternativos as variaveis acima):
NOVAIS_INTERNAL_CLICKUP_TOKEN=pk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOVAIS_INTERNAL_WORKSPACE_ID=123456789

# Webhook ClickUp -> backend
# OBRIGATORIO em producao (NODE_ENV=production). O server recusa subir sem este valor.
# Em dev, pode ficar vazio: nesse caso, validacao de assinatura e DESLIGADA com aviso explicito no log.
CLICKUP_WEBHOOK_SECRET=

# Ambiente runtime
NODE_ENV=development
PORT=3000

# GitHub (opcional, usado pelos sync de evidencia tech/AIOS)
# Necessario para que o sync consulte PRs/branches/CI ao decidir status. Sem ele, o sync roda em modo offline/dry-run.
# OBRIGATORIO no Railway worker: usado pelo bootstrap-marketing-ai-agents-repo.mjs para clonar/pull do repo PRIVADO novais-digital/marketing-ai-agents.
GITHUB_TOKEN=
# Alias suportado:
GH_TOKEN=

# Novais Digital Social — path do repo clonado/montado.
# Local dev: deixe vazio (resolve para ./marketing-ai-agents ou ../marketing-ai-agents).
# Railway worker: defina como /app/marketing-ai-agents (bootstrap script clona ali).
NOVAIS_SOCIAL_PATH=
