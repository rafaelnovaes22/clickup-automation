{
  "version": "0.2",
  "deliveryTypes": ["agentic_saas", "platform", "automation", "hybrid"],
  "deliveryTypeNotes": "Cada template declara delivery_type. Templates agentic exigem prompts/eval/SHADOW; templates platform exigem rollout/smoke/piloto/aceite.",
  "templates": [
    {
      "key": "agent_request",
      "name": "[TEMPLATE] Solicitacao de agente",
      "delivery_type": "agentic_saas",
      "target": {
        "space": "05 Institucional Acme",
        "list": "Solicitacoes de agente",
        "desiredStatus": "rascunho"
      },
      "description": [
        "Entidade: Solicitacao de agente.",
        "Quando usar: CEO/comercial quer iniciar a criacao de um agente de IA.",
        "Objetivo: capturar escopo de negocio em campos simples, sem exigir linguagem tecnica.",
        "Resultado esperado: status 'escopo pronto' dispara a geracao do backlog tecnico correspondente.",
        "Status desejado: rascunho."
      ],
      "fields": [
        { "key": "client_name", "label": "Cliente", "type": "text", "required": true, "example": "Acme Ltda" },
        { "key": "business_problem", "label": "Problema de negocio", "type": "long_text", "required": true, "example": "Comercial demora para qualificar leads e perde timing." },
        { "key": "expected_outcome", "label": "Outcome esperado", "type": "long_text", "required": true, "example": "Lead qualificado com score e proximo passo sugerido." },
        { "key": "agent_type", "label": "Tipo de agente", "type": "select", "required": true, "options": ["SDR", "suporte", "cobranca", "atendimento", "operacao", "analise", "outro"] },
        { "key": "primary_channel", "label": "Canal principal", "type": "select", "required": true, "options": ["whatsapp", "email", "crm", "site", "dashboard", "api", "outro"] },
        { "key": "technical_platforms", "label": "Plataformas tecnicas", "type": "text", "required": true, "example": "ai_agent,whatsapp,node_backend" },
        { "key": "autonomy_level", "label": "Nivel de autonomia", "type": "select", "required": true, "options": ["somente sugerir", "executar com aprovacao", "executar autonomo", "nao sei"] },
        { "key": "human_handoff_rule", "label": "Quando chamar humano", "type": "long_text", "required": true, "example": "Quando o lead pedir desconto, contrato ou falar com diretor." },
        { "key": "success_metric", "label": "Metrica de sucesso", "type": "text", "required": false, "example": "% leads qualificados corretamente" },
        { "key": "delivery_due_date", "label": "Prazo desejado", "type": "date", "required": true, "example": "2026-05-15" },
        { "key": "tech_owner", "label": "Responsavel tecnico", "type": "person_or_text", "required": true, "example": "AI Engineer" },
        { "key": "repository_url", "label": "Repositorio", "type": "url", "required": false, "example": "https://github.com/acme/acme" },
        { "key": "environment", "label": "Ambiente", "type": "select", "required": true, "options": ["dev", "staging", "prod"] }
      ],
      "activities": [
        { "trigger": "template_instantiated", "action": "Criar task Solicitacao de agente" },
        { "trigger": "custom_fields preenchidos", "action": "Validar escopo minimo" },
        { "trigger": "status=escopo pronto", "action": "Gerar payload tecnico e disparar tech.task.generate" }
      ],
      "subtasks": [
        "Preencher cliente, problema e outcome",
        "Selecionar tipo de agente e canal principal",
        "Definir autonomia e regra de handoff humano",
        "Confirmar plataformas tecnicas",
        "Marcar status como escopo pronto"
      ]
    },
    {
      "key": "lead_new",
      "name": "[TEMPLATE] Lead novo",
      "delivery_type": "any",
      "target": {
        "space": "01 Pipeline Comercial",
        "list": "Leads",
        "desiredStatus": "novo"
      },
      "description": [
        "Entidade: Lead.",
        "Quando usar: primeiro contato comercial, indicacao, evento ou form externo.",
        "Objetivo: registrar origem, dor percebida e proximo passo.",
        "Campos minimos: empresa, contato, origem, contexto, dono comercial.",
        "Status desejado: novo."
      ],
      "fields": [
        { "key": "company_name", "label": "Empresa", "type": "text", "required": true, "example": "Acme Ltda" },
        { "key": "contact_name", "label": "Contato principal", "type": "text", "required": true, "example": "Maria Silva" },
        { "key": "contact_email", "label": "Email", "type": "email", "required": false, "example": "maria@acme.com" },
        { "key": "contact_phone", "label": "Telefone/WhatsApp", "type": "phone", "required": false, "example": "+55 11 99999-9999" },
        { "key": "source", "label": "Origem", "type": "select", "required": true, "options": ["indicacao", "evento", "outbound", "inbound", "parceiro", "manual"] },
        { "key": "pain_summary", "label": "Dor percebida", "type": "long_text", "required": true, "example": "Time perde muito tempo qualificando leads manualmente." },
        { "key": "commercial_owner", "label": "Dono comercial", "type": "person_or_text", "required": true, "example": "Rafael" },
        { "key": "next_step_date", "label": "Data do proximo passo", "type": "date", "required": false, "example": "2026-05-08" }
      ],
      "activities": [
        { "trigger": "template_instantiated", "action": "Criar task Lead na lista Leads" },
        { "trigger": "source=indicacao", "action": "Adicionar tag revisao-humana" },
        { "trigger": "next_step_date preenchido", "action": "Definir due date da task" }
      ],
      "subtasks": [
        "Registrar origem e contexto do lead",
        "Definir dono comercial",
        "Agendar ou tentar primeira conversa"
      ]
    },
    {
      "key": "diagnostic_sold",
      "name": "[TEMPLATE] Diagnostico Fase 0 vendido",
      "delivery_type": "any",
      "target": {
        "space": "01 Pipeline Comercial",
        "list": "Diagnosticos Fase 0",
        "desiredStatus": "vendido"
      },
      "description": [
        "Entidade: Diagnostico Fase 0.",
        "Quando usar: pagamento ou aceite comercial confirmado.",
        "Objetivo: conduzir diagnostico pago em 5 dias uteis.",
        "Resultado esperado: relatorio 5-10pp + sessao de devolucao.",
        "Status desejado: vendido."
      ],
      "fields": [
        { "key": "company_name", "label": "Empresa", "type": "text", "required": true, "example": "Acme Ltda" },
        { "key": "lead_task_id", "label": "Task do lead", "type": "clickup_task_id", "required": false, "example": "86abc123" },
        { "key": "diagnostic_fee", "label": "Fee do diagnostico", "type": "currency_brl", "required": true, "example": 8000 },
        { "key": "payment_confirmed_at", "label": "Pagamento confirmado em", "type": "datetime", "required": true, "example": "2026-05-01T14:00:00-03:00" },
        { "key": "client_ceo_name", "label": "CEO do cliente", "type": "text", "required": true, "example": "Maria Silva" },
        { "key": "client_ceo_email", "label": "Email do CEO", "type": "email", "required": false, "example": "maria@acme.com" },
        { "key": "start_date", "label": "Data de inicio", "type": "date", "required": true, "example": "2026-05-04" },
        { "key": "delivery_date", "label": "Data de devolucao", "type": "date", "required": true, "example": "2026-05-08" },
        { "key": "diagnostic_owner", "label": "Responsavel tecnico", "type": "person_or_text", "required": true, "example": "Tech Lead" }
      ],
      "activities": [
        { "trigger": "template_instantiated", "action": "Criar task Diagnostico Fase 0" },
        { "trigger": "task_created", "action": "Criar 6 subtasks padrao D+1 a D+5" },
        { "trigger": "lead_task_id preenchido", "action": "Relacionar/linkar task de lead" },
        { "trigger": "delivery_date preenchido", "action": "Definir due date da devolucao" }
      ],
      "subtasks": [
        "D+1 - Sessao estruturada 90min com CEO",
        "D+1 - Entrevistas 30min com 2-3 pessoas-chave",
        "D+2 - Auditoria express de dados e ferramentas",
        "D+3 - Analise de 3 candidatos e criterios SaaS2",
        "D+4 - Redacao do relatorio",
        "D+5 - Sessao de devolucao 1h"
      ]
    },
    {
      "key": "proposal_sent",
      "name": "[TEMPLATE] Proposta enviada",
      "delivery_type": "any",
      "target": {
        "space": "01 Pipeline Comercial",
        "list": "Propostas",
        "desiredStatus": "enviada"
      },
      "description": [
        "Entidade: Proposta.",
        "Quando usar: cliente aprovou diagnostico e pediu proposta SaaS2.",
        "Objetivo: negociar escopo, pricing, cap, SLA e clausula de outcome.",
        "Resultado esperado: assinatura ou rejeicao registrada.",
        "Status desejado: enviada."
      ],
      "fields": [
        { "key": "company_name", "label": "Empresa", "type": "text", "required": true, "example": "Acme Ltda" },
        { "key": "diagnostic_task_id", "label": "Task do diagnostico", "type": "clickup_task_id", "required": true, "example": "86diag123" },
        { "key": "sku", "label": "SKU proposto", "type": "text", "required": true, "example": "Qualificacao de Leads SaaS2" },
        { "key": "platform_fee", "label": "Fee plataforma mensal", "type": "currency_brl", "required": true, "example": 3000 },
        { "key": "outcome_price", "label": "Preco por outcome", "type": "currency_brl", "required": true, "example": 80 },
        { "key": "monthly_cap", "label": "Cap mensal", "type": "currency_brl", "required": true, "example": 12000 },
        { "key": "sla_threshold", "label": "SLA threshold", "type": "percent", "required": true, "example": 90 },
        { "key": "proposal_url", "label": "Link da proposta", "type": "url", "required": false, "example": "https://..." },
        { "key": "valid_until", "label": "Validade da proposta", "type": "date", "required": true, "example": "2026-05-20" }
      ],
      "activities": [
        { "trigger": "template_instantiated", "action": "Criar task Proposta" },
        { "trigger": "proposal_url preenchido", "action": "Adicionar link na descricao" },
        { "trigger": "valid_until preenchido", "action": "Definir due date de follow-up" },
        { "trigger": "status=assinada", "action": "Disparar template setup_created" }
      ],
      "subtasks": [
        "Validar clausula de outcome",
        "Validar pricing plataforma + outcome + cap",
        "Enviar proposta final",
        "Coletar assinatura digital",
        "Confirmar setup fee"
      ]
    },
    {
      "key": "setup_created",
      "name": "[TEMPLATE] Setup tecnico iniciado",
      "delivery_type": "any",
      "target": {
        "space": "02 Implantacao",
        "list": "Setups em andamento",
        "desiredStatus": "kickoff"
      },
      "description": [
        "Entidade: Setup.",
        "Quando usar: proposta assinada e setup fee confirmado.",
        "Objetivo: preparar cliente para SHADOW.",
        "Resultado esperado: canal conectado, baseline capturado, prompts aprovados e smoke test verde.",
        "Status desejado: kickoff."
      ],
      "fields": [
        { "key": "company_name", "label": "Empresa", "type": "text", "required": true, "example": "Acme Ltda" },
        { "key": "client_task_id", "label": "Task do cliente", "type": "clickup_task_id", "required": false, "example": "86cli123" },
        { "key": "proposal_task_id", "label": "Task da proposta", "type": "clickup_task_id", "required": true, "example": "86prop123" },
        { "key": "setup_fee", "label": "Setup fee", "type": "currency_brl", "required": true, "example": 15000 },
        { "key": "setup_owner", "label": "Responsavel pelo setup", "type": "person_or_text", "required": true, "example": "Delivery" },
        { "key": "entry_channel", "label": "Canal de entrada", "type": "select", "required": true, "options": ["whatsapp", "email", "webhook", "form", "outro"] },
        { "key": "kickoff_date", "label": "Data do kickoff", "type": "datetime", "required": true, "example": "2026-05-06T10:00:00-03:00" },
        { "key": "target_shadow_date", "label": "Data alvo para SHADOW", "type": "date", "required": true, "example": "2026-05-15" }
