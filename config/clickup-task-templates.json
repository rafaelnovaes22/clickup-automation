        { "trigger": "task_created", "action": "Criar 6 subtasks padrao de setup" },
        { "trigger": "target_shadow_date preenchido", "action": "Definir due date do setup" },
        { "trigger": "status=shadow ligado", "action": "Disparar template shadow_active" }
      ],
      "subtasks": [
        "Kickoff com cliente",
        "Coletar briefing institucional",
        "Mapear processo agent-ready",
        "Conectar canal de entrada",
        "Capturar baseline cost humano",
        "Aprovar prompts iniciais e rodar smoke test"
      ]
    },
